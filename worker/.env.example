# Kafka broker (Redpanda Cloud or local Redpanda)
KAFKA_BROKER=seed-xxx.redpanda.com:9092

# SASL credentials (leave empty for local plaintext)
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Region for local dev (on Fly.io, FLY_REGION is set automatically)
# Allowed values: eu-west | us-east | ap-south
WORKER_REGION=eu-west

# Laravel API endpoint that receives probe results
RESULT_API_URL=http://localhost:8000/api/internal/probe-result

# Must match INTERNAL_TOKEN in Laravel .env
INTERNAL_TOKEN=
