COMPOSE_PROJECT_NAME=node-watch

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=node_watch
MYSQL_USER=node_watch
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka (Redpanda)
KAFKA_HOST=redpanda
KAFKA_PORT=9092
KAFKA_ADMIN_PORT=9644
KAFKA_REST_PORT=8082
